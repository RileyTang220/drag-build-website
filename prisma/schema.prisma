// Prisma schema for drag-website
// Database models for user authentication, pages, and versions

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}


// Connection URLs are owned by `prisma.config.ts` (Prisma 7 forbids `url` /
// `directUrl` in schema.prisma — see P1012).
//
// Two-URL pattern for serverless deployments:
//   - Migrations  → DIRECT_URL  (set in prisma.config.ts → datasource.url)
//   - App runtime → DATABASE_URL (set in lib/prisma.ts → PrismaPg adapter)
//
// Locally (docker-compose, no pooler) the two env vars point at the same DB.
datasource db {
  provider = "postgresql"
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  pages         Page[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Page models
model Page {
  id                 String   @id @default(cuid())
  ownerId            String
  title              String
  slug               String?
  draftSchema        Json // Current draft schema (JSONB)
  publishedVersionId String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner            User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  publishedVersion PageVersion?  @relation("PublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  versions         PageVersion[]

  @@index([ownerId])
  @@index([slug])
}

model PageVersion {
  id          String   @id @default(cuid())
  pageId      String
  schema      Json // Immutable published schema (JSONB)
  createdAt   DateTime @default(now())
  publishedAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  publishedOnPage Page? @relation("PublishedVersion")

  @@index([pageId])
}
