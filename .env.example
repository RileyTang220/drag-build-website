# 复制为 .env 或 .env.local 后填写（勿提交含真实密码的文件）

# ── 本地开发：Docker Compose 默认库 ─────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webbuilder"

# ── Vercel / 生产：不要在仓库里写真实密码 ───────────────────────
# 在 Vercel → Project → Settings → Environment Variables 里单独配置 DATABASE_URL，例如：
# postgresql://postgres:你的密码@db.xxxxx.supabase.co:5432/postgres?sslmode=require

NEXTAUTH_URL="http://localhost:3000"
# 本地与 Vercel 生产环境都必须配置；Vercel → Environment Variables 添加同名变量
NEXTAUTH_SECRET="请用 openssl rand -base64 32 生成"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
