# Copy to `.env` or `.env.local` and fill in. Never commit real secrets.
#
# ─── Database ──────────────────────────────────────────────────────────────────
# This project uses the "two-URL pattern" required for serverless production:
#
#   DATABASE_URL — runtime, points at a connection pooler (pgbouncer /
#                  Supavisor in transaction mode). Required on Vercel so
#                  Lambda invocations don't exhaust Postgres `max_connections`.
#
#   DIRECT_URL   — `prisma migrate` and `prisma db push` use this. It must be
#                  a direct connection (not pooled), because migrations need
#                  advisory locks and prepared statements.
#
# Locally (docker-compose, no pooler) the two URLs are the same.
# In production they MUST differ.
#
# Local docker-compose example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webbuilder"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/webbuilder"

# Production (Supabase) example — set these on Vercel, NOT in this file:
#   DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   DIRECT_URL=postgresql://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres?sslmode=require
#
# `DIRECT_URL` does NOT need to be set on Vercel runtime — it's only used by
# the migration job in CI. Treat it as a privileged secret.

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# In production NEXTAUTH_URL must exactly match the deployed origin (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── DeepSeek API (AI page generation) ───────────────────────────────────────
# Required if you want the "AI generator" tab on /templates to work. Without
# it, the rest of the app still functions; the AI section just shows an error.
# DeepSeek's API is OpenAI-compatible — we use the `openai` SDK pointed at
# https://api.deepseek.com/v1 and the model `deepseek-chat`.
# Get a key from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""
